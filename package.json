{
  "name": "x-reply-sorter",
  "displayName": "X Reply Sorter",
  "version": "0.1.0",
  "description": "No more rage bait from the algorithm. Automatically sort X/Twitter replies by Likes, Recent, or Relevant.",
  "author": "Zac Cooper",
  "license": "MIT",
  "homepage": "https://zacooper5g.github.io/x-reply-sorter/",
  "repository": {
    "type": "git",
    "url": "https://github.com/zacooper5g/x-reply-sorter"
  },
  "bugs": {
    "url": "https://github.com/zacooper5g/x-reply-sorter/issues"
  },
  "keywords": [
    "chrome-extension",
    "twitter",
    "x",
    "sort-replies",
    "tweet-replies",
    "browser-extension",
    "manifest-v3",
    "reply-sorter",
    "twitter-extension",
    "sort-by-likes"
  ],
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.11.0",
    "plasmo": "^0.89.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "prettier": "^3.3.0"
  },
  "manifest": {
    "permissions": [
      "storage",
      "activeTab"
    ],
    "host_permissions": [
      "https://x.com/*",
      "https://twitter.com/*"
    ]
  }
}
